#!/bin/bash
set -eo pipefail

REPO_DIR=/tmp/repo
SITE_DIR=/site

log() {
  if [ $# -gt 0 ]; then
    echo "⛵ [skiff] $*"
  else
    sed 's/^/⛵ [skiff] /'
  fi
}

sync_continuously() {
  sleep 5  # Wait for nginx

  while true; do
    if sync; then
      log "Synced."
    else
      log "Error during sync, will retry..."
    fi

    sleep 10
  done
}

sync() {
  sync_site_assets && sync_server_conf
}

sync_site_assets() {
  log "Fetching ${GIT_BRANCH:-HEAD}..."

  if [ -d "$REPO_DIR/.git" ]; then
    # Subsequent runs: fetch and check for changes
    cd "$REPO_DIR"
    OLD_HEAD=$(git rev-parse HEAD)
    git fetch --depth 1 origin "${GIT_BRANCH:-HEAD}" 2>&1 | log

    # Skip sync if no changes
    if [ "$OLD_HEAD" = "$(git rev-parse FETCH_HEAD)" ]; then
      log "Already up to date."
      return 0
    fi
    git reset --hard FETCH_HEAD 2>&1 | log
  else
    # First run: shallow clone
    rm -rf "$REPO_DIR"
    git clone --depth 1 ${GIT_BRANCH:+--branch "$GIT_BRANCH"} "$GIT_URL" "$REPO_DIR" 2>&1 | log
  fi

  # Sync to site
  rsync -a --delete --exclude='config/' --exclude='serve' "$REPO_DIR/" "$SITE_DIR/"
}

sync_server_conf() {
  local repo_conf="$REPO_DIR/config/server.conf"
  local site_conf="$SITE_DIR/config/server.conf"
  local backup_conf="$SITE_DIR/config/server.conf.bak"

  [ -f "$repo_conf" ] || return 0

  if [ -f "$site_conf" ] && cmp -s "$repo_conf" "$site_conf"; then
    return 0
  fi

  log "Detected change to config/server.conf, validating and reloading nginx..."
  mkdir -p "$SITE_DIR/config"

  if [ -f "$site_conf" ]; then
    cp "$site_conf" "$backup_conf"
  else
    rm -f "$backup_conf"
  fi

  cp "$repo_conf" "$site_conf"

  if nginx -t 2>&1 | log && nginx -s reload 2>&1 | log; then
    rm -f "$backup_conf"
    log "Reloaded nginx with updated server.conf."
    return 0
  else
    if [ -f "$backup_conf" ]; then
      cp "$backup_conf" "$site_conf"
      rm -f "$backup_conf"
      log "Reverted config/server.conf to last known good version."
    fi

    log "server.conf changed, but nginx could not be restarted."
    return 1
  fi
}


# Start continuously syncing in background if GIT_URL is set
[[ "$GIT_URL" ]] && sync_continuously &
nginx -g 'daemon off;'

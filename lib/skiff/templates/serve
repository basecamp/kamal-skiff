#!/bin/bash
set -e

REPO_DIR=/tmp/repo
SITE_DIR=/site

polling_clone() {
  # Wait for nginx to be ready
  sleep 5

  while true; do
    echo "Fetching latest..."

    # Clone/fetch into a temp directory with minimal history
    if [ -d "$REPO_DIR/.git" ]; then
      cd $REPO_DIR
      git fetch --depth 1 origin ${GIT_BRANCH:-HEAD}
      git reset --hard FETCH_HEAD
    else
      rm -rf $REPO_DIR
      git clone --depth 1 ${GIT_BRANCH:+--branch $GIT_BRANCH} $GIT_URL $REPO_DIR
    fi

    # Sync site files (excluding config which is already in the image)
    rsync -a --delete --exclude='config/' --exclude='serve' $REPO_DIR/ $SITE_DIR/

    sleep 10
  done
}

# When GIT_URL is set start polling in the background
[[ "$GIT_URL" ]] && polling_clone &

# Start NGINX in the foreground
nginx -g 'daemon off;'
